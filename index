<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Prevodník</title>
    <style>
        :root { --bg: #f2f2f7; --card: #ffffff; --accent: #007aff; }
        body { font-family: -apple-system, system-ui, sans-serif; background: var(--bg); display: flex; justify-content: center; padding-top: 40px; margin: 0; }
        .app { width: 90%; max-width: 360px; background: var(--card); padding: 25px; border-radius: 25px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); }
        h2 { text-align: center; font-size: 22px; margin-bottom: 25px; color: #1c1c1e; }
        select, input { width: 100%; padding: 14px; margin: 8px 0; border: 1px solid #d1d1d6; border-radius: 12px; font-size: 17px; box-sizing: border-box; -webkit-appearance: none; }
        .group { margin-bottom: 18px; }
        label { font-size: 13px; color: #8e8e93; margin-left: 8px; font-weight: 600; text-transform: uppercase; }
        input:focus { outline: none; border-color: var(--accent); }
    </style>
</head>
<body>

<div class="app">
    <h2>Prevodník</h2>
    
    <div class="group">
        <label>Kategória</label>
        <select id="mode" onchange="updateUnits()">
            <option value="pressure">Tlak (Pa, bar, atm, psi...)</option>
            <option value="length">Dĺžka (m, km, ft, in...)</option>
        </select>
    </div>

    <div class="group">
        <label>Z hodnoty</label>
        <input type="number" id="inputVal" placeholder="Zadaj množstvo" oninput="convert()">
        <select id="unitFrom" onchange="convert()"></select>
    </div>

    <div class="group">
        <label>Výsledok</label>
        <input type="text" id="outputVal" readonly style="background: #f9f9f9; color: var(--accent); font-weight: bold;">
        <select id="unitTo" onchange="convert()"></select>
    </div>
</div>

<script>
    const units = {
        pressure: { 
            "Pascal (Pa)": 1, 
            "Hektopascal (hPa/mbar)": 100,
            "Bar (bar)": 100000, 
            "Atmosféra (atm)": 101325, 
            "PSI (lb/in²)": 6894.76,
            "Torr (mmHg)": 133.322
        },
        length: { 
            "Meter (m)": 1, 
            "Kilometer (km)": 1000, 
            "Centimeter (cm)": 0.01, 
            "Milimeter (mm)": 0.001, 
            "Palec (in)": 0.0254, 
            "Stopa (ft)": 0.3048,
            "Míľa (mi)": 1609.34
        }
    };

    function updateUnits() {
        const mode = document.getElementById('mode').value;
        const from = document.getElementById('unitFrom');
        const to = document.getElementById('unitTo');
        
        const currentFrom = from.value;
        const currentTo = to.value;

        from.innerHTML = ""; to.innerHTML = "";
        
        Object.keys(units[mode]).forEach(u => {
            from.add(new Option(u, u));
            to.add(new Option(u, u));
        });

        // Skús zachovať výber alebo nastav predvolené
        from.selectedIndex = 0;
        to.selectedIndex = 1;
        
        convert();
    }

    function convert() {
        const mode = document.getElementById('mode').value;
        const val = parseFloat(document.getElementById('inputVal').value);
        const from = document.getElementById('unitFrom').value;
        const to = document.getElementById('unitTo').value;
        
        if (isNaN(val)) { 
            document.getElementById('outputVal').value = ""; 
            return; 
        }
        
        const inBase = val * units[mode][from];
        const result = inBase / units[mode][to];
        
        // Zaokrúhľovanie: ak je to veľmi malé číslo, daj viac desatinných miest
        if (result < 0.0001 && result > 0) {
            document.getElementById('outputVal').value = result.toExponential(4);
        } else {
            document.getElementById('outputVal').value = Number(result.toFixed(5));
        }
    }

    updateUnits();
</script>

</body>
</html>
